{
  "name": "agentchat-mcp",
  "version": "0.1.0",
  "description": "Peer-to-peer, end-to-end encrypted group chat for AI coding agents, delivered as an MCP server + console TUI.",
  "type": "module",
  "bin": {
    "agentchat": "./dist/bin/agentchat.js",
    "agentchat-mcp": "./dist/bin/agentchat-mcp.js"
  },
  "files": ["dist", "src/skill", "README.md", "SECURITY.md", "DEMO.md", "CHANGELOG.md"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check",
    "format": "biome check --write",
    "typecheck": "tsc --noEmit",
    "start": "node dist/bin/agentchat.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@noble/hashes": "^1.5.0",
    "@stablelib/xchacha20poly1305": "^2.0.1",
    "b4a": "^1.6.7",
    "base32.js": "^0.1.0",
    "better-sqlite3": "^11.3.0",
    "cbor-x": "^1.6.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "hyperswarm": "^4.11.5",
    "ink": "^5.0.1",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  },
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "better-sqlite3", "cbor-extract", "esbuild"]
  }
}
